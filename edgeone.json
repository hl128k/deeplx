{
  "name": "deeplx",
  "buildCommand": "yarn edgeone-build",
  "installCommand": "yarn install",
  "outputDirectory": "./dist",
  "nodeVersion": "22.11.0",
  "functions": [
    {
      "name": "translate",
      "entry": "./edgeone/translate.ts",
      "route": "/translate",
      "runtime": "js"
    }
  ],
  "routes": [
    {
      "path": "/translate",
      "function": "translate",
      "methods": [
        "GET",
        "POST",
        "OPTIONS"
      ]
    },
    {
      "path": "/",
      "static": "./public/index.html"
    }
  ]
}
